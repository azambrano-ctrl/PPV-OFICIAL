# Streaming
RTMP_SERVER_URL=rtmp://your-server.com/live
HLS_BASE_URL=https://your-cdn.com/hls
STREAM_TOKEN_EXPIRES_IN=3h

# CDN (BunnyCDN o CloudFlare)
